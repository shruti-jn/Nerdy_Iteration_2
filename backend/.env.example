# ===== Live AI Video Tutor — Environment Variables =====

# --- API Keys ---
# Deepgram: STT (Speech-to-Text) using Nova-3 model
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Groq: LLM inference (Llama 3.3 70B Versatile for tutoring, Llama 3.1 8B Instant for summaries)
GROQ_API_KEY=your_groq_api_key_here

# Cartesia: TTS (Text-to-Speech) using Sonic-3 model
CARTESIA_API_KEY=your_cartesia_api_key_here
CARTESIA_VOICE_ID=your_cartesia_voice_id_here
TTS_PROVIDER=cartesia

# ElevenLabs: TTS (Text-to-Speech) using Flash v2.5 model
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Simli: Avatar rendering with lip-sync via WebRTC
SIMLI_API_KEY=your_simli_api_key_here

# Pydantic Logfire: Structured tracing and observability
LOGFIRE_TOKEN=your_logfire_token_here

# Braintrust: LLM evaluation logging and scoring dashboard
BRAINTRUST_API_KEY=your_braintrust_api_key_here

# --- Orchestrator ---
# Which orchestrator to use: "custom" (default) or "livekit" (future)
ORCHESTRATOR=custom

# --- Session ---
# Maximum conversational turns per tutoring session
MAX_TURNS=15

# --- Latency Budgets (milliseconds) ---
# Target = ideal latency, Max = maximum acceptable before FAIL
STT_TARGET_MS=150
STT_MAX_MS=300
LLM_TTFT_TARGET_MS=200
LLM_TTFT_MAX_MS=400
TTS_TARGET_MS=150
TTS_MAX_MS=300
AVATAR_TARGET_MS=100
AVATAR_MAX_MS=200
TOTAL_TARGET_MS=500
TOTAL_MAX_MS=1000

# --- Simli ---
# Face ID for the avatar (get from Simli dashboard)
SIMLI_FACE_ID=your_simli_face_id_here

# --- Server ---
HOST=0.0.0.0
PORT=8000
