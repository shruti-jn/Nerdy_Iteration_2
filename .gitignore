# Ignore all Markdown files by default.
*.md

# Allow the explicitly permitted Markdown files.
!README.md
!ARCHITECTURE.md
!BUILD_SUMMARY.md
!CLAUDE.md
!RUNBOOK.md

# Python
.venv/
backend/venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/

# Environment
.env
backend/.env

# IDE
.cursor/
.vscode/

# Node
frontend/node_modules/
frontend/.next/
frontend/dist/

# Logs (dirs tracked, log files ignored)
backend/logs/*.log
backend/logs/*.log.*
frontend/logs/*.log

# Session data
backend/data/

# OS
.DS_Store
